# ─── LLM PROVIDER ──────────────────────────────────────────
# "gemini"            → use Google Gemini via ADK (default)
# "openai_compatible" → use any OpenAI-compatible endpoint via LiteLLM
LLM_PROVIDER=gemini

# ─── OPENAI-COMPATIBLE ENDPOINT (used when LLM_PROVIDER=openai_compatible) ──
# Set these to point at Nebius / vLLM / Ollama / LM Studio / etc.
OPENAI_API_BASE=https://your-endpoint/v1/
OPENAI_API_KEY=your-api-key
OPENAI_MODEL=moonshotai/Kimi-K2.5

# ─── REQUIRED ───────────────────────────────────────────────
# Gemini / Google AI Studio API key
GOOGLE_API_KEY=AIza...

# GCP project for Firestore, Cloud Storage, Cloud Run
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_REGION=us-central1

# ─── OPTIONAL: VERTEX AI (alternative to API key) ────────────
# Set to "true" to use Vertex AI instead of AI Studio
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_LOCATION=us-central1

# ─── IMAGE & MEDIA GENERATION ────────────────────────────────
# Choose "imagen" (Google) or "flux2" (Modal)
IMAGE_PROVIDER=imagen

# Modal Flux.2 endpoint URL (if using flux2)
MODAL_FLUX2_ENDPOINT_URL=https://...

# Optional: Modal tokens for private endpoints
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# ─── FIRESTORE ───────────────────────────────────────────────
FIRESTORE_DATABASE=(default)

# ─── CLOUD STORAGE (for produced video files) ────────────────
GCS_BUCKET=your-project-content-pipeline

# ─── RESEARCH ────────────────────────────────────────────────
# Optional: Tavily for high-quality research (fallback to DuckDuckGo)
TAVILY_API_KEY=tvly-...

# Optional: Firecrawl for deep web scraping
FIRECRAWL_API_KEY=fc-...

# ─── TTS ─────────────────────────────────────────────────────
# Optional: ElevenLabs for premium voice (fallback to free Edge TTS)
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Default Edge TTS voice (used if ElevenLabs is not configured)
DEFAULT_VOICE=en-US-AriaNeural

# ─── YOUTUBE ─────────────────────────────────────────────────
# YouTube Data API v3 OAuth credentials
YOUTUBE_CLIENT_ID=...
YOUTUBE_CLIENT_SECRET=...
YOUTUBE_REFRESH_TOKEN=...

# ─── GOOGLE CALENDAR ─────────────────────────────────────────
CALENDAR_ID=primary
CALENDAR_CLIENT_ID=...
CALENDAR_CLIENT_SECRET=...
CALENDAR_REFRESH_TOKEN=...

# ─── APP CONFIG ──────────────────────────────────────────────
# Gemini model to use
GEMINI_MODEL=gemini-3-flash-preview

# Demo mode: skips heavy production tasks (TTS, video assembly, upload)
# Set to "false" for full production pipeline
DEMO_MODE=true

# App name (used for ADK session namespacing)
APP_NAME=youtube-content-pipeline

# Log level
LOG_LEVEL=INFO
