# ─── LLM PROVIDER ──────────────────────────────────────────
# "gemini"            → use Google Gemini via ADK (default)
# "openai_compatible" → use any OpenAI-compatible endpoint via LiteLLM
LLM_PROVIDER=gemini

# ─── OPENAI-COMPATIBLE ENDPOINT (used when LLM_PROVIDER=openai_compatible) ──
# Set these to point at Nebius / vLLM / Ollama / LM Studio / etc.
OPENAI_API_BASE=https://your-endpoint/v1/
OPENAI_API_KEY=your-api-key
OPENAI_MODEL=moonshotai/Kimi-K2.5

# ─── REQUIRED ───────────────────────────────────────────────
# Gemini / Google AI Studio API key
GOOGLE_API_KEY=AIza...

# GCP project for Firestore, Cloud Storage, Cloud Run
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_REGION=us-central1

# ─── OPTIONAL: VERTEX AI (alternative to API key) ────────────
# Set to "true" to use Vertex AI instead of AI Studio
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_LOCATION=us-central1

# ─── IMAGE & MEDIA GENERATION ────────────────────────────────
# Choose "imagen" (Imagen 3/4), "gemini" (Gemini native image gen), or "flux2" (Modal)
IMAGE_PROVIDER=gemini

# Model ID for Gemini native image generation (used when IMAGE_PROVIDER=gemini)
# Supported: gemini-2.5-flash-image (GA), gemini-3.1-flash-image-preview, gemini-3-pro-image-preview
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Location override for image generation. If empty, uses GOOGLE_CLOUD_LOCATION.
# Useful when LLM needs "global" but image gen works better on a specific region.
IMAGE_GENERATION_LOCATION=us-central1

# Modal Flux.2 endpoint URL (if using flux2)
MODAL_FLUX2_ENDPOINT_URL=https://...

# Optional: Modal tokens for private endpoints
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# ─── FIRESTORE ───────────────────────────────────────────────
FIRESTORE_DATABASE=(default)

# ─── CLOUD STORAGE (for produced video files) ────────────────
GCS_BUCKET=your-project-content-pipeline

# ─── RESEARCH ────────────────────────────────────────────────
# Optional: Tavily for high-quality research (fallback to DuckDuckGo)
TAVILY_API_KEY=tvly-...

# Optional: Firecrawl for deep web scraping
FIRECRAWL_API_KEY=fc-...

# ─── TTS ─────────────────────────────────────────────────────
# Optional: ElevenLabs for premium voice (fallback to free Edge TTS)
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Default Edge TTS voice (used if ElevenLabs is not configured)
DEFAULT_VOICE=en-US-AriaNeural

# ─── YOUTUBE ─────────────────────────────────────────────────
# YouTube Data API v3 OAuth credentials
YOUTUBE_CLIENT_ID=...
YOUTUBE_CLIENT_SECRET=...
YOUTUBE_REFRESH_TOKEN=...

# Optional: dedicated API key for YouTube Data API v3 trending lookups.
# If not set, GOOGLE_API_KEY is used — but its GCP project must have
# YouTube Data API v3 enabled at:
# https://console.developers.google.com/apis/api/youtube.googleapis.com
YOUTUBE_DATA_API_KEY=

# ─── GOOGLE CALENDAR ─────────────────────────────────────────
CALENDAR_ID=primary
CALENDAR_CLIENT_ID=...
CALENDAR_CLIENT_SECRET=...
CALENDAR_REFRESH_TOKEN=...

# ─── FIREBASE AUTH ────────────────────────────────────────────
# Firebase Web API key (from Firebase Console → Project Settings → General)
FIREBASE_API_KEY=

# ─── APP BASE URL ─────────────────────────────────────────────
# Public base URL — must match an Authorized JavaScript Origin in your
# Google Cloud OAuth 2.0 client. Change to your Cloud Run URL in production.
APP_BASE_URL=http://localhost:8080

# ─── APP CONFIG ──────────────────────────────────────────────
# Gemini model to use
GEMINI_MODEL=gemini-3-flash-preview

# Demo mode: skips heavy production tasks (TTS, video assembly, upload)
# Set to "false" for full production pipeline
DEMO_MODE=true

# App name (used for ADK session namespacing)
APP_NAME=youtube-content-pipeline

# Log level
LOG_LEVEL=INFO
